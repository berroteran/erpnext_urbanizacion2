  "main_section": null,
  "main_section_html": "<style>\r\n* { box-sizing: border-box; margin: 0; padding: 0; }\r\n.imp-container { background: white; border-radius: 12px; padding: 40px; max-width: 680px; margin: 40px auto; box-shadow: 0 2px 12px rgba(0,0,0,0.08); }\r\n.imp-logo { font-size: 13px; font-weight: 600; letter-spacing: 2px; color: #888; text-transform: uppercase; margin-bottom: 8px; }\r\n.imp-container h1 { font-size: 22px; font-weight: 600; color: #1a1a1a; margin-bottom: 6px; }\r\n.imp-subtitle { font-size: 14px; color: #888; margin-bottom: 32px; }\r\n.imp-drop-zone { border: 1.5px dashed #d0d0d0; border-radius: 10px; padding: 48px 20px; text-align: center; cursor: pointer; transition: all 0.2s; background: #fafafa; }\r\n.imp-drop-zone:hover, .imp-drop-zone.drag-over { border-color: #4B6BFB; background: #f0f3ff; }\r\n.imp-drop-icon { font-size: 13px; font-weight: 700; letter-spacing: 2px; color: #4B6BFB; background: #f0f3ff; display: inline-block; padding: 8px 14px; border-radius: 6px; margin-bottom: 16px; }\r\n.imp-drop-text { font-size: 15px; color: #555; margin-bottom: 8px; }\r\n.imp-drop-hint { font-size: 12px; color: #aaa; }\r\n.imp-btn-select { display: inline-block; margin-top: 16px; padding: 8px 20px; background: #4B6BFB; color: white; border-radius: 6px; font-size: 13px; cursor: pointer; border: none; font-weight: 500; }\r\n.imp-preview { display: none; }\r\n.imp-preview-header { background: #f0f3ff; border-radius: 8px; padding: 16px 20px; margin-bottom: 20px; }\r\n.imp-preview-proyecto { font-size: 16px; font-weight: 600; color: #1a1a1a; }\r\n.imp-preview-count { font-size: 13px; color: #666; margin-top: 4px; }\r\n.imp-table { width: 100%; border-collapse: collapse; font-size: 13px; margin-bottom: 20px; }\r\n.imp-table thead tr { background: #f5f5f5; }\r\n.imp-table th { padding: 8px 10px; text-align: left; font-weight: 500; color: #555; border-bottom: 1px solid #eee; }\r\n.imp-table td { padding: 7px 10px; color: #333; border-bottom: 1px solid #f0f0f0; }\r\n.imp-table tr:last-child td { border-bottom: none; }\r\n.imp-more-row td { color: #aaa; font-style: italic; text-align: center; }\r\n.imp-badge { display: inline-block; padding: 2px 8px; border-radius: 20px; font-size: 11px; font-weight: 500; }\r\n.imp-badge-modelo { background: #e8f5e9; color: #2e7d32; }\r\n.imp-badge-sinmodelo { background: #f3e5f5; color: #6a1b9a; }\r\n.imp-badge-extras { background: #fff3e0; color: #e65100; }\r\n.imp-actions { display: flex; gap: 10px; align-items: center; }\r\n.imp-btn-importar { flex: 1; padding: 12px; background: #2e7d32; color: white; border: none; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; }\r\n.imp-btn-importar:hover { background: #1b5e20; }\r\n.imp-btn-importar:disabled { background: #aaa; cursor: not-allowed; }\r\n.imp-btn-reset { padding: 12px 20px; background: white; color: #666; border: 1px solid #ddd; border-radius: 8px; font-size: 14px; cursor: pointer; }\r\n.imp-progress { display: none; margin-top: 20px; }\r\n.imp-progress-bar-wrap { background: #f0f0f0; border-radius: 20px; height: 10px; margin: 10px 0; overflow: hidden; }\r\n.imp-progress-bar { height: 10px; background: #2e7d32; border-radius: 20px; width: 0%; transition: width 0.3s; }\r\n.imp-progress-text { font-size: 13px; color: #555; }\r\n.imp-resultado { display: none; border-radius: 8px; padding: 20px; margin-top: 20px; }\r\n.imp-resultado.success { background: #e8f5e9; }\r\n.imp-resultado.warning { background: #fff8e1; }\r\n.imp-resultado h3 { font-size: 15px; font-weight: 600; margin-bottom: 10px; }\r\n.imp-resultado.success h3 { color: #2e7d32; }\r\n.imp-resultado.warning h3 { color: #f57f17; }\r\n.imp-resultado p { font-size: 13px; color: #444; margin-bottom: 6px; }\r\n.imp-errores { margin-top: 10px; font-size: 12px; color: #444; max-height: 200px; overflow-y: auto; line-height: 2; }\r\n.imp-error { background: #fff3f3; border: 1px solid #ffcdd2; border-radius: 8px; padding: 12px 16px; font-size: 13px; color: #c62828; margin-top: 16px; display: none; }\r\n</style>\r\n\r\n<div class=\"imp-container\">\r\n  <div class=\"imp-logo\">GICOSA</div>\r\n  <h1>Importador de Lotes</h1>\r\n  <p class=\"imp-subtitle\">Sube el Excel y los lotes se crean automáticamente en el sistema</p>\r\n\r\n  <div class=\"imp-drop-zone\" id=\"impDropZone\">\r\n    <div class=\"imp-drop-icon\">XLS</div>\r\n    <p class=\"imp-drop-text\">Arrastra el archivo Excel aquí</p>\r\n    <p class=\"imp-drop-hint\">Formato estándar: Proyecto en A1 &middot; Encabezados en fila 4 &middot; Datos desde fila 5</p>\r\n    <input type=\"file\" id=\"impFileInput\" accept=\".xlsx,.xls\" style=\"display:none\">\r\n    <button class=\"imp-btn-select\" onclick=\"document.getElementById('impFileInput').click()\">Seleccionar archivo</button>\r\n  </div>\r\n\r\n  <div class=\"imp-error\" id=\"impErrorMsg\"></div>\r\n\r\n  <div class=\"imp-preview\" id=\"impPreview\">\r\n    <div class=\"imp-preview-header\">\r\n      <div class=\"imp-preview-proyecto\" id=\"impPrevProyecto\"></div>\r\n      <div class=\"imp-preview-count\" id=\"impPrevCount\"></div>\r\n    </div>\r\n    <table class=\"imp-table\">\r\n      <thead>\r\n        <tr>\r\n          <th>Lote</th><th>Bloque</th><th>Modelo</th>\r\n          <th>M2</th><th>V2</th><th>Extras</th><th>Tipo</th><th>Esquinero</th>\r\n        </tr>\r\n      </thead>\r\n      <tbody id=\"impPreviewBody\"></tbody>\r\n    </table>\r\n    <div class=\"imp-actions\">\r\n      <button class=\"imp-btn-importar\" id=\"impBtnImportar\">Importar Lotes al Sistema</button>\r\n      <button class=\"imp-btn-reset\" onclick=\"impResetear()\">Cancelar</button>\r\n    </div>\r\n    <div class=\"imp-progress\" id=\"impProgress\">\r\n      <div class=\"imp-progress-bar-wrap\">\r\n        <div class=\"imp-progress-bar\" id=\"impProgressBar\"></div>\r\n      </div>\r\n      <p class=\"imp-progress-text\" id=\"impProgressText\">Importando...</p>\r\n    </div>\r\n  </div>\r\n\r\n  <div class=\"imp-resultado\" id=\"impResultado\">\r\n    <h3 id=\"impResultadoTitulo\"></h3>\r\n    <p id=\"impResultadoMsg\"></p>\r\n    <div class=\"imp-errores\" id=\"impResultadoErrores\"></div>\r\n    <br>\r\n    <button class=\"imp-btn-reset\" onclick=\"impResetear()\">Importar otro archivo</button>\r\n  </div>\r\n</div>\r\n\r\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js\"></script>\r\n<script>\r\n  let impLotesData = [];\r\n  let impProyectoNombre = '';\r\n\r\n  document.getElementById('impDropZone').addEventListener('dragover', e => { e.preventDefault(); document.getElementById('impDropZone').classList.add('drag-over'); });\r\n  document.getElementById('impDropZone').addEventListener('dragleave', () => document.getElementById('impDropZone').classList.remove('drag-over'));\r\n  document.getElementById('impDropZone').addEventListener('drop', e => {\r\n    e.preventDefault();\r\n    document.getElementById('impDropZone').classList.remove('drag-over');\r\n    if (e.dataTransfer.files[0]) impProcesarArchivo(e.dataTransfer.files[0]);\r\n  });\r\n  document.getElementById('impFileInput').addEventListener('change', e => {\r\n    if (e.target.files[0]) impProcesarArchivo(e.target.files[0]);\r\n  });\r\n\r\n  function impNormalizarEsquinero(val) {\r\n    if (!val) return 'No';\r\n    const v = String(val).trim().toUpperCase()\r\n      .normalize('NFD').replace(/[\\u0300-\\u036f]/g, '');\r\n    return ['SI', 'S', '1', 'YES', 'TRUE'].includes(v) ? 'Si' : 'No';\r\n  }\r\n\r\n  function impProcesarArchivo(file) {\r\n    if (!file) return;\r\n    const reader = new FileReader();\r\n    reader.onload = function(e) {\r\n      try {\r\n        const wb = XLSX.read(e.target.result, { type: 'array' });\r\n        const ws = wb.Sheets[wb.SheetNames[0]];\r\n        const data = XLSX.utils.sheet_to_json(ws, { header: 1, defval: null });\r\n\r\n        let rawProyecto = data[0][0] || '';\r\n        impProyectoNombre = rawProyecto.replace(/\\s*\\(.*?\\)\\s*/g, '').replace(/\\s+/g, ' ').trim();\r\n\r\n        if (!impProyectoNombre) {\r\n          impMostrarError('No se encontró el nombre del proyecto en la celda A1.');\r\n          return;\r\n        }\r\n\r\n        impLotesData = [];\r\n        for (let i = 4; i < data.length; i++) {\r\n          const row = data[i];\r\n          if (!row || !row[1]) continue;\r\n\r\n          const loteCompleto = String(row[1]).trim();\r\n          const bloque = loteCompleto.split('-')[0] || '';\r\n          const tieneModelo = row[2] && String(row[2]).trim() !== '';\r\n          const rawExtras = row[5];\r\n          const tieneExtras = rawExtras !== null && rawExtras !== undefined && parseFloat(rawExtras) > 0;\r\n          const v2_extras = tieneExtras ? parseFloat(parseFloat(rawExtras).toFixed(3)) : 0;\r\n          const m2_extras = tieneExtras ? parseFloat((v2_extras / 1.4196).toFixed(3)) : 0;\r\n\r\n          impLotesData.push({\r\n            numero_lote: loteCompleto,\r\n            name: impProyectoNombre + '-' + loteCompleto,\r\n            bloque: bloque,\r\n            catalogo_modelos: tieneModelo ? String(row[2]).trim() : '',\r\n            m2_terreno: row[3] ? parseFloat(parseFloat(row[3]).toFixed(3)) : 0,\r\n            v2_terreno: row[4] ? parseFloat(parseFloat(row[4]).toFixed(3)) : 0,\r\n            v2_extras: v2_extras,\r\n            m2_extras: m2_extras,\r\n            esquinero: impNormalizarEsquinero(row[6]),\r\n            tipo_lote: tieneModelo ? 'Con Modelo de Casa' : 'Sin Modelo de Casa',\r\n            estado: 'Disponible',\r\n            tieneExtras: tieneExtras,\r\n            tieneModelo: tieneModelo\r\n          });\r\n        }\r\n\r\n        if (impLotesData.length === 0) {\r\n          impMostrarError('No se encontraron lotes. Verifica que los datos comiencen en la fila 5.');\r\n          return;\r\n        }\r\n        impMostrarPreview();\r\n      } catch(err) {\r\n        impMostrarError('Error al leer el archivo: ' + err.message);\r\n      }\r\n    };\r\n    reader.readAsArrayBuffer(file);\r\n  }\r\n\r\n  function impMostrarPreview() {\r\n    document.getElementById('impErrorMsg').style.display = 'none';\r\n    document.getElementById('impPrevProyecto').textContent = 'Proyecto: ' + impProyectoNombre;\r\n    document.getElementById('impPrevCount').textContent =\r\n      impLotesData.length + ' lotes encontrados · ' +\r\n      impLotesData.filter(l => l.tieneExtras).length + ' con extras · ' +\r\n      impLotesData.filter(l => !l.tieneModelo).length + ' sin modelo';\r\n\r\n    const tbody = document.getElementById('impPreviewBody');\r\n    tbody.innerHTML = '';\r\n    impLotesData.slice(0, 8).forEach(l => {\r\n      const tr = document.createElement('tr');\r\n      const tipoBadge = l.tieneModelo\r\n        ? '<span class=\"imp-badge imp-badge-modelo\">Con modelo</span>'\r\n        : '<span class=\"imp-badge imp-badge-sinmodelo\">Sin modelo</span>';\r\n      tr.innerHTML =\r\n        '<td><b>' + l.numero_lote + '</b></td>' +\r\n        '<td>' + l.bloque + '</td>' +\r\n        '<td>' + (l.catalogo_modelos || '<span style=\"color:#aaa\">—</span>') + '</td>' +\r\n        '<td>' + l.m2_terreno + '</td>' +\r\n        '<td>' + l.v2_terreno + '</td>' +\r\n        '<td>' + (l.tieneExtras ? '<span class=\"imp-badge imp-badge-extras\">' + l.v2_extras + '</span>' : '<span style=\"color:#aaa\">—</span>') + '</td>' +\r\n        '<td>' + tipoBadge + '</td>' +\r\n        '<td>' + l.esquinero + '</td>';\r\n      tbody.appendChild(tr);\r\n    });\r\n\r\n    if (impLotesData.length > 8) {\r\n      const tr = document.createElement('tr');\r\n      tr.className = 'imp-more-row';\r\n      tr.innerHTML = '<td colspan=\"8\">... y ' + (impLotesData.length - 8) + ' lotes más</td>';\r\n      tbody.appendChild(tr);\r\n    }\r\n\r\n    document.getElementById('impDropZone').style.display = 'none';\r\n    document.getElementById('impPreview').style.display = 'block';\r\n    document.getElementById('impBtnImportar').onclick = impImportar;\r\n  }\r\n\r\n  async function impImportar() {\r\n    const btn = document.getElementById('impBtnImportar');\r\n    btn.disabled = true;\r\n    btn.textContent = 'Importando...';\r\n    document.getElementById('impProgress').style.display = 'block';\r\n\r\n    let exitosos = 0;\r\n    let errores = [];\r\n    const total = impLotesData.length;\r\n\r\n    for (let i = 0; i < impLotesData.length; i++) {\r\n      const l = impLotesData[i];\r\n      document.getElementById('impProgressBar').style.width = Math.round((i / total) * 100) + '%';\r\n      document.getElementById('impProgressText').textContent = 'Importando ' + (i + 1) + ' de ' + total + ': ' + l.numero_lote + '...';\r\n\r\n      try {\r\n        // Verificar si el lote ya existe\r\n        try {\r\n          const existeRes = await frappe.call({\r\n            method: 'frappe.client.get_value',\r\n            args: { doctype: 'Lotes', filters: { name: l.name }, fieldname: 'name' }\r\n          });\r\n          if (existeRes.message && existeRes.message.name) {\r\n            errores.push({ lote: l.numero_lote, bloque: l.bloque, omitido: true });\r\n            continue;\r\n          }\r\n        } catch(e) { /* no existe, continuar */ }\r\n\r\n        // Obtener datos del catálogo incluyendo ambientes\r\n        let m2_casa = 0;\r\n        let v2_casa = 0;\r\n        let ambientes_lote = [];\r\n        let descripcion_lote = '';\r\n\r\n        if (l.catalogo_modelos) {\r\n          try {\r\n            const catRes = await fetch(\r\n              '/api/resource/CatalogoModelos/' + encodeURIComponent(l.catalogo_modelos),\r\n              { headers: { 'X-Frappe-CSRF-Token': frappe.csrf_token } }\r\n            );\r\n            if (catRes.ok) {\r\n              const catData = await catRes.json();\r\n              m2_casa = catData.data?.area_construccion || 0;\r\n              v2_casa = catData.data?.area_varas || parseFloat((m2_casa * 1.4196).toFixed(3));\r\n              ambientes_lote = (catData.data?.ambientes || []).map(function(a) {\r\n                return { ambiente: a.ambiente, cantidad: a.cantidad };\r\n              });\r\n              descripcion_lote = catData.data?.descripcion || '';\r\n            } else {\r\n              errores.push({ lote: l.numero_lote, bloque: l.bloque, omitido: false, error: 'Modelo \"' + l.catalogo_modelos + '\" no encontrado en el Catálogo' });\r\n              continue;\r\n            }\r\n          } catch(e) {\r\n            errores.push({ lote: l.numero_lote, bloque: l.bloque, omitido: false, error: 'Error al leer catálogo: ' + e.message });\r\n            continue;\r\n          }\r\n        }\r\n\r\n        // Crear el lote\r\n        await fetch('/api/resource/Lotes', {\r\n          method: 'POST',\r\n          headers: { 'Content-Type': 'application/json', 'X-Frappe-CSRF-Token': frappe.csrf_token },\r\n          body: JSON.stringify({\r\n            doctype: 'Lotes',\r\n            name: l.name,\r\n            proyecto: impProyectoNombre,\r\n            bloque: l.bloque,\r\n            numero_lote: l.numero_lote,\r\n            tipo_lote: l.tipo_lote,\r\n            catalogo_modelos: l.catalogo_modelos || null,\r\n            m2_terreno: l.m2_terreno,\r\n            v2_terreno: l.v2_terreno,\r\n            m2_casa: m2_casa,\r\n            v2_casa: v2_casa,\r\n            m2_extras: l.m2_extras || 0,\r\n            v2_extras: l.v2_extras || 0,\r\n            esquinero: l.esquinero,\r\n            estado: l.estado,\r\n            ambientes: ambientes_lote,\r\n            descripcion_construccion: descripcion_lote\r\n          })\r\n        }).then(async res => {\r\n          if (!res.ok) {\r\n            const err = await res.json();\r\n            throw new Error(err.exc_type || err.message || 'Error desconocido');\r\n          }\r\n          exitosos++;\r\n        });\r\n\r\n      } catch(e) {\r\n        errores.push({ lote: l.numero_lote, bloque: l.bloque, omitido: false, error: e.message });\r\n      }\r\n    }\r\n\r\n    document.getElementById('impProgressBar').style.width = '100%';\r\n    document.getElementById('impPreview').style.display = 'none';\r\n    document.getElementById('impProgress').style.display = 'none';\r\n\r\n    const omitidos = errores.filter(e => e.omitido);\r\n    const fallidos = errores.filter(e => !e.omitido);\r\n\r\n    const resDiv = document.getElementById('impResultado');\r\n    resDiv.style.display = 'block';\r\n    resDiv.className = 'imp-resultado ' + (fallidos.length === 0 ? 'success' : 'warning');\r\n\r\n    let titulo = exitosos + ' lotes importados';\r\n    if (omitidos.length > 0) titulo += ' · ' + omitidos.length + ' ya existían';\r\n    if (fallidos.length > 0) titulo += ' · ' + fallidos.length + ' con errores';\r\n    document.getElementById('impResultadoTitulo').textContent = titulo;\r\n    document.getElementById('impResultadoMsg').textContent = 'Proyecto: ' + impProyectoNombre;\r\n\r\n    if (errores.length > 0) {\r\n      const lineas = [];\r\n      if (fallidos.length > 0) {\r\n        lineas.push('<b style=\"color:#c62828\">Errores:</b>');\r\n        fallidos.forEach(e => lineas.push('• <b>' + e.lote + '</b> (Bloque ' + e.bloque + '): ' + e.error));\r\n      }\r\n      if (omitidos.length > 0) {\r\n        if (fallidos.length > 0) lineas.push('');\r\n        lineas.push('<b style=\"color:#888\">Omitidos (ya existían):</b>');\r\n        omitidos.forEach(e => lineas.push('• <b>' + e.lote + '</b> (Bloque ' + e.bloque + ')'));\r\n      }\r\n      document.getElementById('impResultadoErrores').innerHTML = lineas.join('<br>');\r\n    }\r\n  }\r\n\r\n  function impMostrarError(msg) {\r\n    const el = document.getElementById('impErrorMsg');\r\n    el.innerHTML = msg;\r\n    el.style.display = 'block';\r\n  }\r\n\r\n  function impResetear() {\r\n    impLotesData = [];\r\n    impProyectoNombre = '';\r\n    document.getElementById('impDropZone').style.display = 'block';\r\n    document.getElementById('impPreview').style.display = 'none';\r\n    document.getElementById('impProgress').style.display = 'none';\r\n    document.getElementById('impResultado').style.display = 'none';\r\n    document.getElementById('impErrorMsg').style.display = 'none';\r\n    document.getElementById('impFileInput').value = '';\r\n    const btn = document.getElementById('impBtnImportar');\r\n    if (btn) { btn.disabled = false; btn.textContent = 'Importar Lotes al Sistema'; }\r\n  }\r\n</script>",
